# ─────────────────────────────────────────────────────────────────────────────
# ai-saas-starter environment
# Copy to .env and fill in. Validation lives in src/lib/env.ts — the app fails
# fast at boot with a readable error listing anything missing or malformed.
# Optional vars degrade gracefully (noted per var below).
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (required) ──────────────────────────────────────────────────────
# Postgres connection string. Works with local Docker, Neon, or Supabase.
# Local dev: `docker compose up -d` starts Postgres 17 with exactly this URL.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/ai_saas_starter

# ── Better Auth (required) ───────────────────────────────────────────────────
# Secret used to sign sessions and tokens. Min 32 chars.
# Generate one: openssl rand -base64 32
BETTER_AUTH_SECRET=
# Canonical URL of the app, no trailing slash. Defaults to http://localhost:3000.
BETTER_AUTH_URL=http://localhost:3000

# ── OAuth providers (optional) ───────────────────────────────────────────────
# Leave a pair empty to hide that login button. Set both vars of a pair or none.
# Google: https://console.cloud.google.com/apis/credentials
#   Redirect URI: {BETTER_AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GitHub: https://github.com/settings/developers
#   Callback URL: {BETTER_AUTH_URL}/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Email — Resend (optional) ────────────────────────────────────────────────
# Without RESEND_API_KEY, emails no-op with a console warning and magic-link
# login is disabled. Get a key: https://resend.com/api-keys
RESEND_API_KEY=
# Sender address. Must be a verified domain in Resend, or use the shared
# onboarding sender for testing. "Name <email>" format is fine.
EMAIL_FROM="AI SaaS Starter <onboarding@resend.dev>"

# ── Stripe (required in production, optional in development) ─────────────────
# Without these in development, the app still boots: features.billing turns
# off, the billing page shows a setup card, and checkout actions throw a
# clear "Stripe is not configured" error. Production fails fast without them.
# Secret key (test mode: sk_test_...): https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=
# Webhook signing secret (whsec_...). Local dev: printed by `pnpm stripe:listen`.
# Production: from the webhook endpoint you create in the Stripe dashboard.
STRIPE_WEBHOOK_SECRET=
# Publishable key (pk_test_...). Optional: Checkout uses server-side redirects,
# so this is only needed if you embed Stripe.js yourself.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Price IDs (price_..., NOT prod_...). Create Products in the Stripe dashboard:
#   Pro    — $9/month recurring
#   Ultra  — $29/month recurring
#   Top-up — $5 one-time (100 credits)
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_ULTRA_MONTHLY=
STRIPE_PRICE_TOPUP_100=

# ── AI image generation ──────────────────────────────────────────────────────
# Vercel AI Gateway key: https://vercel.com/docs/ai-gateway
# Optional when AI_MOCK=true; required for real generation.
AI_GATEWAY_API_KEY=
# Model string, "provider/model" format. Swap without touching code.
AI_IMAGE_MODEL=openai/gpt-image-1
# true = skip the provider and return a placeholder image. Free local dev and
# e2e tests. Never enable in production.
AI_MOCK=false

# ── Rate limiting — Upstash Redis (optional) ─────────────────────────────────
# Without these, rate limiting falls back to a per-instance in-memory limiter
# (fine for dev, not for serverless production). https://console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Storage — Vercel Blob (optional) ─────────────────────────────────────────
# Without this, generated images are written to ./.generated locally (dev only).
# Production needs it: https://vercel.com/docs/vercel-blob
BLOB_READ_WRITE_TOKEN=
